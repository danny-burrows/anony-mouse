const introductionParagraphs = [
  "In a quaint little town, there is a popular face-painting stall run by a kind old lady named Grandma Lily. She is famous for her beautiful and whimsical face paintings, but none are more beloved than the mysterious mouse character she paints, known as Anony-Mouse.",
  "Grandma Lily discovered an old enchanted paintbrush in her attic and used it to create the Anony-Mouse face painting. During the day, children flock to her stall to ask for Anony-Mouse, with his big round ears, twinkling eyes, and tiny whiskers. Every child who wears his image feels a special burst of joy and excitement.",
  "What the children do not know is that Anony-Mouse comes to life at night. When the moon rises high in the sky, he steps out of the face paints and into the real world. He loves to explore, spread happiness, and visit the dreams of the children who wore his face painting during the day.",
  "One day, Grandma Lily notices that the children seem happier and more confident. As she hears about their magical dreams, she smiles knowingly and reveals that Anony-Mouse was a character she created long ago to help children feel brave and happy. She never expected him to come to life, but she is delighted by the joy he brings.",
  "And so the story ends with Anony-Mouse continuing his nightly adventures, promising that as long as children need a friend in their dreams, he will be there.",
];
---

<BaseLayout
  title="Anony-Mouse | Whimsical trilogies for young readers"
  description="Discover Anony-Mouse trilogy collections with room for Kindle and Audible purchase links."
>
  <main class="page-shell">
    <section class="hero">
      <div class="hero__content">
        <p class="eyebrow hero__eyebrow">Anony-Mouse</p>
        <h1>
          <span class="hero__headline hero__headline--small">Tiny paws.</span>
          <span class="hero__headline hero__headline--large"
            >Big adventures.</span
          >
        </h1>
        <p class="hero__lede">
          Meet Anony-Mouse, the little hero at the center of playful trilogies
          made for cozy reading, family listening, and bedtime wonder.
        </p>

        <div class="hero__actions">
          <a class="button button--primary" href="#collections"
            >Browse trilogies</a
          >
          <a class="button button--secondary" href="#story">Read the story</a>
        </div>

        <ul class="format-chips" aria-label="Available formats">
          {availableFormats.map((format) => <li>{format}</li>)}
        </ul>
      </div>

      <div class="hero__visual" aria-hidden="true">
        <div class="cover-stack">
          <div
            class="cover-stack__card cover-stack__card--front"
            style={heroCoverStyle}
          >
            <span>Meet the hero</span>
            <strong class="cover-stack__title cover-stack__title--brand"
              >Anony-Mouse</strong
            >
          </div>
          <div class="cover-stack__card cover-stack__card--middle">
            <span>Bramble Brook</span>
            <strong class="cover-stack__title">Trilogy</strong>
          </div>
          <div class="cover-stack__card cover-stack__card--back">
            <span>Starlight Harbor</span>
            <strong class="cover-stack__title">Audio + Text</strong>
          </div>
        </div>
      </div>

      <div class="hero__paw-trail" aria-hidden="true">
        {
          heroFootprints.map((footprint) => (
            <span
              class="paw-print"
              style={`--paw-x: ${footprint.x}; --paw-y: ${footprint.y}; --paw-size: ${footprint.size}; --paw-rotation: ${footprint.rotation}; --paw-color: ${footprint.color}; --paw-delay: ${footprint.delay}; --paw-drift-x: ${footprint.driftX}; --paw-drift-y: ${footprint.driftY};`}
            />
          ))
        }
      </div>
    </section>

    <section class="origin-story" id="story">
      <div class="origin-story__intro">
        <p class="eyebrow">How It Began</p>
        <h2>The magic behind Anony-Mouse.</h2>
        <p class="origin-story__lead">
          A gentle origin story about Grandma Lily, an enchanted paintbrush, and
          the little mouse who brings bravery and joy into children's dreams.
        </p>

        <ul
          class="origin-story__highlights"
          aria-label="Origin story highlights"
        >
          {storyHighlights.map((highlight) => <li>{highlight}</li>)}
        </ul>
      </div>

      <div class="origin-story__spine" aria-hidden="true">
        <span class="origin-story__ribbon"></span>
      </div>

      <div class="origin-story__body">
        {introductionParagraphs.map((paragraph) => <p>{paragraph}</p>)}
      </div>
    </section>

    <section class="collections" id="collections">
      <div class="section-heading">
        <p class="eyebrow">Featured collections</p>
        <h2>Pick an Anony-Mouse trilogy.</h2>
        <p>
          Each collection below is ready for a Kindle link, an Audible link, or
          both.
        </p>
      </div>

      <div class="collections__grid">
        {
          trilogies.map((trilogy, index) => (
            <TrilogyCard trilogy={trilogy} index={index} />
          ))
        }
      </div>
    </section>

    <section class="closing-callout">
      <div>
        <p class="eyebrow">Ready for launch</p>
        <h2>Publish now, wire in store pages when they are live.</h2>
      </div>
      <p>
        The landing page is already structured around trilogy-level purchase
        cards, so the remaining work is just dropping the final Kindle and
        Audible URLs into the content file.
      </p>
    </section>
  </main>
</BaseLayout>
