---
import TrilogyCard from "../components/TrilogyCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { trilogies } from "../data/trilogies";

const baseUrl = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const heroCoverStyle = `--cover-image: url("${baseUrl}images/meet-the-hero.png");`;

const availableFormats = [
  "Kindle trilogy bundles",
  "Audible-friendly audio sets",
  "Whimsical stories for read-aloud time",
];

const storyHighlights = [
  "Grandma Lily's enchanted paintbrush",
  "A secret hero who wakes at moonrise",
  "Dreamtime adventures that make children feel brave",
];

